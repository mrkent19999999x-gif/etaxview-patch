<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
<xsl:include href="../../include/TKhaiHeader.xsl"/>
 <xsl:include href="../../include/TKhaiFooter.xsl"/>    
	<xsl:template match="/">
		<xsl:variable name="tkchinh" select='HSoKhaiThue/CTieuTKhaiChinh' />
		<xsl:variable name="moTaBieuMau" select="'Ban hành kèm theo Thông tư số 28/2011/TT-BTC ngày 28/02/2011 của Bộ Tài chính'" />
		 <xsl:call-template name="tkhaiHeader">
		<xsl:with-param name="mauTKhai"   select="'01/BVMT'"/>
		<xsl:with-param name="moTaBieuMau"   select="$moTaBieuMau"/>
		<xsl:with-param name="ghuchuTK"   select="''"/>
	  </xsl:call-template>
		<div class="ndungtkhai_div">
		<table>		
			<tr>
				<td class="align-r">
					<i>Đơn vị tiền: Đồng Việt Nam </i>
				</td>
			</tr>
			<tr>
				<td>
					<table class="tkhai_table"  >
							<thead>
							 <tr class="tkhaiheader">     
							  <td  class="align-c" height="30" width="40px" rowspan="2">STT</td>
							  <td  class="align-c" width="500px" rowspan="2">Loại khoáng sản</td>
							  <td  class="align-c" width="200px" colspan="2" >Số lượng khoáng sản</td>
							  <td  class="align-c" width="100px" rowspan="2">Mức phí</td> 
							  <td  class="align-c"  width="120px"  rowspan="2">Số phí phải nộp trong kỳ</td>
							</tr>
							<tr class="tkhaiheader">     
							  <td  class="align-c" height="30">Đơn vị tính</td>
							  <td  class="align-c" >Số lượng</td>
							</tr>
							 <tr class="tkhaiheader">  
							  <td class="align-c">(1)</td>          
							  <td class="align-c">(2)</td>
							  <td class="align-c">(3)</td>
							  <td class="align-c">(4)</td>
							  <td class="align-c">(5)</td>
							  <td class="align-c">(6)=(4)x(5)</td>
							 </tr>
							 </thead>     
							 <tr>  
							  <td class="align-l" colspan="5">         <div>
									 <i><b>I. Khoáng sản do cơ sở tự khai thác:</b></i>
								 </div>      </td>
							  <td class="align-r" width="120px">
								  <b><xsl:value-of select="$tkchinh/PhiBVMT/KSCSoTuKhaiThac/tongPhiDaKeKhai"/></b>
							  </td>
							 </tr>     
							
							<xsl:for-each select="$tkchinh/PhiBVMT/KSCSoTuKhaiThac/KhoangSan/KhoangSan">
							<xsl:variable name="currentRows" select='position()' />
							  <tr>
							   <td class="align-c" width="40px"><xsl:value-of select="$currentRows" /></td>
							   <td class="align-l" ><xsl:value-of select="loaiKSan"/></td>
							   <td class="align-c" width="100px"><xsl:value-of select="SoLuongKS/donViTinh"/></td>
							   <td class="align-r" width="100px"><xsl:value-of select="SoLuongKS/soLuong"/></td>
							   <td class="align-r" ><xsl:value-of select="mucPhi"/></td>
							   <td class="align-r" ><xsl:value-of select="soPhiPNop"/></td>
							  </tr>
							 </xsl:for-each>
							
							 <tr>  
							  <td class="align-l" colspan="5">         <div>
									 <i><b>II. Khoáng sản do cơ sở thu mua nộp thay người khai thác:</b></i>
								 </div>      </td>
							  <td class="align-r"><b><xsl:value-of select="$tkchinh/PhiBVMT/KSanCoSoThuMuaNopThay/tongPhiDaKeKhai"/></b></td>
							 </tr>     
							
							<xsl:for-each select="$tkchinh/PhiBVMT/KSanCoSoThuMuaNopThay/KhoangSan/KhoangSan">
							<xsl:variable name="currentRows" select='position()' />
							  <tr>
							  <td class="align-c" width="40px"><xsl:value-of select="$currentRows" /></td>
							   <td class="align-l" ><xsl:value-of select="loaiKSan"/></td>
							   <td class="align-c" width="100px"><xsl:value-of select="SoLuongKS/donViTinh"/></td>
							   <td class="align-r" width="100px"><xsl:value-of select="SoLuongKS/soLuong"/></td>
							   <td class="align-r" ><xsl:value-of select="mucPhi"/></td>
							   <td class="align-r" ><xsl:value-of select="soPhiPNop"/></td>
							  </tr>
							 </xsl:for-each>							 
							  <tr>
								<td colspan="5" class="align-c"><b>Tổng cộng:</b></td>  
								<td class="align-r" width="120px"><b><xsl:value-of select="$tkchinh/tongPhiPNop"/></b></td>
							  </tr>							 
							 </table>
					  </td>
				  </tr>
				  <tr>
					<td >
						Số tiền phí bảo vệ môi trường đối với khai thác khoáng sản phải nộp vào NSNN trong kỳ này là (ghi bằng chữ): <b><xsl:value-of select="$tkchinh/bangChu"/></b>
					  </td>
				  </tr>
				  </table>
      </div>		
		<xsl:call-template name="tkhaiFooter"/>


	</xsl:template>		
</xsl:stylesheet>