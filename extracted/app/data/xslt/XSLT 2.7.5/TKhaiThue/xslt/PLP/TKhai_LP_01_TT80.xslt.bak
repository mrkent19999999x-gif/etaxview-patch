<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
xmlns:ihtkk="http://www.nhantokhai.gdt.gov.vn/xslt">
<xsl:include href="../../include/TKhaiHeader.xsl"/>
 <xsl:include href="../../include/TKhaiFooter.xsl"/>    
  <xsl:include href="../../common/common.xsl"/>   
	<xsl:template match="/">
		<xsl:variable name="tkchinh" select='HSoThueDTu/HSoKhaiThue/CTieuTKhaiChinh' />
		 <xsl:variable name="moTaBieuMau" select="'Ban hành kèm theo Thông tư số 
80/2021/TT-BTC ngày 29 tháng 9 năm 2021 của Bộ trưởng Bộ Tài chính
'" />
		 <xsl:call-template name="tkhaiHeader_PHLP">
		<xsl:with-param name="mauTKhai"   select="'01/LP'"/>
		<xsl:with-param name="moTaBieuMau"   select="$moTaBieuMau"/>
		<xsl:with-param name="ghuchuTK"   select="''"/>
	  </xsl:call-template>
		<div class="ndungtkhai_div">
		<table>		
			
			<tr>
				<td>
					<table class="tkhai_table"  >
							<thead>
							 <tr class="tkhaiheader"> 
							  <td>STT</td>
							  <td>Loại lệ phí</td>
							  <td>Tiểu mục</td>      
							  <td>Đơn vị tiền</td>
							  <td>Số tiền lệ phí phải nộp NSNN</td>
							</tr>
							 <tr class="tkhaiheader">  
							  <td class="align-c" >(1)</td>          
							  <td class="align-c" >(2a)</td>
							  <td class="align-c" >(2b)</td>
							  <td class="align-c" >(3)</td>
							  <td class="align-c" >(4)</td>
							 </tr>     
							</thead>
							 <xsl:for-each select="$tkchinh/NoiDung01LP/ChiTietLePhi">
									<xsl:variable name="currentRows" select='position()' />
							  <tr>
							   <td class="align-c"><xsl:value-of select="$currentRows" /></td>
							   <td class="align-l"><xsl:value-of select="ten_LoaiLePhi"/></td>
							   <td class="align-c"><xsl:value-of select="tieuMuc"/></td>
							   <td class="align-c"><xsl:value-of select="ma_DonViTien"/></td>
							   <td class="align-r"><xsl:value-of select="ihtkk:formatNumber(soTienPHPhaiNop)"/></td>
							  </tr>
							  </xsl:for-each>
							  
							  
							  <xsl:for-each select="$tkchinh/TongCong01LP/ChiTietTongCongTheoLoaiTien">
									<xsl:variable name="currentRows" select='position()' />
							  <tr>
							 
							   <td colspan="4">
							   <b>Tổng cộng &#160;<xsl:value-of select="ma_DonViTien"/></b></td>
							   <td class="align-r"><b><xsl:value-of select="ihtkk:formatNumber(tongCong)"/></b></td>
							  </tr>
							  </xsl:for-each>
							  							  
							  <tr>
							  <xsl:if test="$tkchinh/NoiDung01LP_TT63/ChiTietLePhiTT63/ten_LoaiLePhi_TT63!= ''" >
							  <td colspan="5">
							  
											<b>Lệ phí thu theo Thông tư số 63/2023/TT-BTC</b>
							 
							
							  
							  </td>
							  </xsl:if>
								</tr>
								<xsl:for-each select="$tkchinh/NoiDung01LP_TT63/ChiTietLePhiTT63">
									<xsl:variable name="currentRows" select='position()' />
								<tr>	
							  <xsl:if test="ten_LoaiLePhi_TT63!= ''" >
							   <td class="align-c"><xsl:value-of select="$currentRows" /></td>
							   <td class="align-l"><xsl:value-of select="ten_LoaiLePhi_TT63"/></td>
							   <td class="align-c"><xsl:value-of select="tieuMuc_TT63"/></td>
							   <td class="align-c"><xsl:value-of select="ma_DonViTien_TT63"/></td>
							   <td class="align-r"><xsl:value-of select="ihtkk:formatNumber(soTienPHPhaiNop_TT63)"/></td>
							   </xsl:if>
							  </tr>
							  </xsl:for-each>
							  
							  
							 </table>
</td>
								   </tr>
													 
									</table>
      </div>	
<table style="page-break-inside: avoid;width:100%" >
<tr>
<td>		  
		<xsl:call-template name="tkhaiFooter"/>
<div id="sigDiv"></div>
</td>
</tr>
</table>		


	</xsl:template>		
</xsl:stylesheet>