{
  "$schema": "https://opencode.ai/config.json",
  "name": "etaxview-patch",
  "version": "1.0.0",
  "description": "iTaxViewer Reverse Engineering Project",
  "mcp": {
    "jadx": {
      "type": "local",
      "command": ["jadx"],
      "environment": {
        "JADX_WORKSPACE": "/root/etaxview-patch/extracted/app"
      },
      "enabled": true
    },
    "fridora": {
      "type": "local",
      "command": ["fridora-mcp"],
      "environment": {
        "FRIDORA_SCRIPTS_DIR": "/root/etaxview-patch/scripts/frida"
      },
      "enabled": true
    }
  }
}
