{
  "name": "etaxview-patch",
  "version": "1.0.0",
  "description": "iTaxViewer Reverse Engineering Project",
  "configuration": {
    "mcpServers": {
      "jadx": {
        "command": "jadx",
        "args": [],
        "env": {
          "JADX_WORKSPACE": "/root/etaxview-patch/extracted/app"
        },
        "alwaysAllow": []
      },
      "fridora": {
        "command": "fridora-mcp",
        "args": [],
        "env": {
          "FRIDORA_SCRIPTS_DIR": "/root/etaxview-patch/scripts/frida"
        },
        "alwaysAllow": []
      }
    },
    "targets": {
      "primary": {
        "path": "/root/etaxview-patch/extracted/app/itaxviewer.jar",
        "type": "java-archive",
        "description": "Main iTaxViewer application"
      },
      "updater": {
        "path": "/root/etaxview-patch/extracted/app/update/updater.jar",
        "type": "java-archive",
        "description": "Auto-update component"
      },
      "launcher": {
        "path": "/root/etaxview-patch/extracted/app/iTaxViewer.exe",
        "type": "win32-pe",
        "description": "Native Windows launcher"
      }
    }
  }
}
